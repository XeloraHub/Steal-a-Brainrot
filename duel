local function MakeBtn(label, sublabel, ypos, accentCol, iconText)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(1, -28, 0, 72)
    Card.Position = UDim2.new(0, 14, 0, ypos)
    Card.BackgroundColor3 = Color3.fromRGB(16, 14, 26)
    Card.BorderSizePixel = 0
    Card.Parent = Main
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 12)

    local CardStroke = Instance.new("UIStroke")
    CardStroke.Color = Color3.fromRGB(40, 35, 65)
    CardStroke.Thickness = 1
    CardStroke.Parent = Card

    local LeftBar = Instance.new("Frame")
    LeftBar.Size = UDim2.new(0, 3, 0.6, 0)
    LeftBar.Position = UDim2.new(0, 0, 0.2, 0)
    LeftBar.BackgroundColor3 = accentCol
    LeftBar.BorderSizePixel = 0
    LeftBar.Parent = Card
    Instance.new("UICorner", LeftBar).CornerRadius = UDim.new(0, 2)

    local IconFrame = Instance.new("Frame")
    IconFrame.Size = UDim2.new(0, 40, 0, 40)
    IconFrame.Position = UDim2.new(0, 14, 0.5, -20)
    IconFrame.BackgroundColor3 = Color3.fromRGB(22, 18, 38)
    IconFrame.BorderSizePixel = 0
    IconFrame.Parent = Card
    Instance.new("UICorner", IconFrame).CornerRadius = UDim.new(0, 8)

    local IconStroke = Instance.new("UIStroke")
    IconStroke.Color = accentCol
    IconStroke.Thickness = 1
    IconStroke.Transparency = 0.5
    IconStroke.Parent = IconFrame

    local Icon = Instance.new("TextLabel")
    Icon.Size = UDim2.new(1, 0, 1, 0)
    Icon.BackgroundTransparency = 1
    Icon.Text = iconText
    Icon.TextSize = 20
    Icon.Font = Enum.Font.GothamBold
    Icon.TextColor3 = accentCol
    Icon.Parent = IconFrame

    local BtnLabel = Instance.new("TextLabel")
    BtnLabel.Size = UDim2.new(1, -80, 0, 22)
    BtnLabel.Position = UDim2.new(0, 64, 0, 13)
    BtnLabel.BackgroundTransparency = 1
    BtnLabel.Text = label
    BtnLabel.TextColor3 = Color3.fromRGB(215, 205, 255)
    BtnLabel.TextSize = 16
    BtnLabel.Font = Enum.Font.GothamBold
    BtnLabel.TextXAlignment = Enum.TextXAlignment.Left
    BtnLabel.Parent = Card

    local SubLbl = Instance.new("TextLabel")
    SubLbl.Size = UDim2.new(1, -80, 0, 18)
    SubLbl.Position = UDim2.new(0, 64, 0, 38)
    SubLbl.BackgroundTransparency = 1
    SubLbl.Text = sublabel
    SubLbl.TextColor3 = Color3.fromRGB(90, 80, 120)
    SubLbl.TextSize = 13
    SubLbl.Font = Enum.Font.Gotham
    SubLbl.TextXAlignment = Enum.TextXAlignment.Left
    SubLbl.Parent = Card

    local Arrow = Instance.new("TextLabel")
    Arrow.Size = UDim2.new(0, 24, 1, 0)
    Arrow.Position = UDim2.new(1, -32, 0, 0)
    Arrow.BackgroundTransparency = 1
    Arrow.Text = ">"
    Arrow.TextColor3 = accentCol
    Arrow.TextSize = 16
    Arrow.Font = Enum.Font.GothamBold
    Arrow.TextTransparency = 0.4
    Arrow.Parent = Card

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    Btn.Parent = Card

    Btn.MouseEnter:Connect(function()
        TweenService:Create(CardStroke, TweenInfo.new(0.15), {
            Color = accentCol,
            Transparency = 0.3
        }):Play()

        TweenService:Create(Arrow, TweenInfo.new(0.15), {
            TextTransparency = 0
        }):Play()
    end)

    Btn.MouseLeave:Connect(function()
        TweenService:Create(CardStroke, TweenInfo.new(0.15), {
            Color = Color3.fromRGB(40, 35, 65),
            Transparency = 0
        }):Play()

        TweenService:Create(Arrow, TweenInfo.new(0.15), {
            TextTransparency = 0.4
        }):Play()
    end)

    return Btn
end

